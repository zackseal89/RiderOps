# ─────────────────────────────────────────────────────────────
# SUPABASE  (required — app won't boot without these)
# Create a project at https://supabase.com/dashboard
# Then run the migration: supabase/migrations/*_init_rms_schema.sql
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─────────────────────────────────────────────────────────────
# SHOPIFY  (required for live order ingestion)
# Settings → Notifications → Webhooks → Create webhook
# Event: Order payment  |  URL: https://your-domain/api/webhooks/shopify
# ─────────────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_hmac_secret
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=your_shopify_admin_api_access_token

# ─────────────────────────────────────────────────────────────
# SHIPDAY  (required for last-mile dispatch & rider GPS)
# Get your API key at https://app.shipday.com/settings/api
# Webhook URL (in Shipday settings): https://your-domain/api/webhooks/shipday
# ─────────────────────────────────────────────────────────────
SHIPDAY_API_KEY=your_shipday_api_key
WAREHOUSE_ADDRESS=123 Pickup Street, Nairobi, Kenya

# ─────────────────────────────────────────────────────────────
# AFRICA'S TALKING  (optional — SMS to customers at status changes)
# Without these, SMS is logged to the console instead.
# https://africastalking.com → Settings → API Keys
# ─────────────────────────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_SHORTCODE=your_sms_shortcode

# ─────────────────────────────────────────────────────────────
# GOOGLE MAPS  (optional — geocoding for delivery routing)
# Without this, town-matching falls back to keyword search.
# https://console.cloud.google.com → Enable: Geocoding API
# ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_server_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key

# ─────────────────────────────────────────────────────────────
# COURIER PARTNERS  (optional — long-distance fallback)
# Without keys, the system generates placeholder tracking IDs.
# Contact each provider to request API access.
#   Fargo: https://www.fargocourier.co.ke
#   Pickup Mtaani: https://www.pickupmtaani.com
#   G4S: https://www.g4s.com/en-ke
# ─────────────────────────────────────────────────────────────
FARGO_API_KEY=your_fargo_api_key
PICKUP_MTAANI_API_KEY=your_pickup_mtaani_api_key
G4S_API_KEY=your_g4s_api_key

# ─────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
DISPATCHER_PASSWORD=change_this_before_going_live
